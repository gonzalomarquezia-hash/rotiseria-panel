# Variables de entorno (para desarrollo local)
# En Vercel, estas variables se configuran en el dashboard

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui

# VAPID Keys (generarlas con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=tu_clave_publica_vapid
VAPID_PRIVATE_KEY=tu_clave_privada_vapid

# API Token para proteger el endpoint de push (generar un string aleatorio)
PUSH_API_TOKEN=tu_token_secreto_aqui
